public class App {
    
    public static void pattern1(int n) {
        if (n > 0) {
            pattern1(n - 1);

            for (int i = 1; i <= n; i++) {
                System.out.print("*");
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        pattern1(5);
    }
}
